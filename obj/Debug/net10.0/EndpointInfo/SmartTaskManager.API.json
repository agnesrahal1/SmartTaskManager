  "components": {
    "schemas": {
      "ChapterDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "estimatedHours": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Difficulty": {
        "enum": [
          "Easy",
          "Medium",
          "Hard"
        ],
        "type": "string"
      },
      "GenerateDto": {
        "type": "object",
        "properties": {
          "hoursPerDay": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LogTimeDto": {
        "type": "object",
        "properties": {
          "minutes": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Priority": {
        "enum": [
          "Low",
          "Medium",
          "High"
        ],
        "type": "string"
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SessionDto": {
        "type": "object",
        "properties": {
          "durationMinutes": {
            "type": "integer",
            "format": "int32"
          },
          "taskId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SubjectDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "color": {
            "type": "string",
            "nullable": true
          },
          "difficulty": {
            "$ref": "#/components/schemas/Difficulty"
          },
          "examDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalHoursNeeded": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "TaskDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "deadline": {
            "type": "string",
            "format": "date-time"
          },
          "manualPriority": {
            "$ref": "#/components/schemas/Priority"
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "estimatedMinutes": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
